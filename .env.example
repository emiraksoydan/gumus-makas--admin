# Kopyalayın: geliştirme için .env.development, production build için .env.production
# Panelin kendi adresi (admin.gumusmakas.com.tr) burada değil — o API appsettings AdminPanel:BaseUrl içindedir.

# Yerel API (npm run dev)
# VITE_API_BASE_URL=https://localhost:7272

# Canlı API (npm run build)
VITE_API_BASE_URL=https://api.gumusmakas.com.tr
